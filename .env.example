# Bot (тот же @community_oncount_bot, что и telegram-bot-2brain.
# До 22.05.2026 на Railway работает старый сервис мастер-класса —
# не запускаем новый polling одновременно, конфликт токена.)
BOT_TOKEN=
BOT_USERNAME=community_oncount_bot

# Web
WEBAPP_URL=http://localhost:8000
JWT_SECRET=change-me-in-production-min-32-chars

# Postgres (на Railway придёт автоматически из plugin)
DATABASE_URL=postgresql+psycopg2://oncount:oncount@localhost:5432/oncount_partners

# Наш api-сервис (NestJS). Централизация Kommo (2026-06-03): партнёр обращается к
# Kommo ТОЛЬКО через api, префикс /api/partner/* под ключом x-api-key. Пусто →
# dev-режим (синк Kommo не регистрируется, лиды квиза 'dry').
ONCOUNT_API_URL=
PARTNER_API_KEY=

# Wazzup24 — отправка WhatsApp. ПОКА напрямую (следующий PR переведёт на api).
# Пустой ключ/канал → dev-режим. TEST_ONLY_NUMBER: если задан — шлём ТОЛЬКО на него.
WAZZUP_API_KEY=
WAZZUP_CHANNEL_ID=
WAZZUP_TEST_ONLY_NUMBER=

# Админ — Telegram ID Николь
ADMIN_TG_ID=6634813047
